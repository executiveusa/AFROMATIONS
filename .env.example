# AFROMATIONS Studios — Environment Variables
# Copy to .env and fill in your values

# --- Synthia Gateway (LLM Proxy) ---
GATEWAY_KEY=your-gateway-key-here
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
OPEN_ROUTER_API=sk-or-...

# --- Hermes WebUI ---
WEBUI_SECRET_KEY=generate-a-random-secret

# --- Supabase ---
SUPABASE_URL=http://31.220.58.212:8001
SUPABASE_KEY=your-supabase-service-key
SUPABASE_ACCESS_TOKEN=sbp_...

# --- Replicate (Seedance 2.0 video generation) ---
REPLICATE_API_TOKEN=r8_...

# --- Blender MCP ---
BLENDER_PATH=blender
RENDER_MODE=local
TEMPLATES_DIR=

# --- Character Creator MCP ---
CC4_DIR=
REALLUSION_TEMPLATES=
REALLUSION_CUSTOM=

# --- Browser MCP ---
CHROME_DEBUG_PORT=9222

# --- Google AI ---
GOOGLE_API_KEY=
GEMINI_API_KEY=

# --- HuggingFace ---
HUGGINGFACE_TOKEN=hf_...

# --- GitHub ---
GH_PAT=ghp_...

# --- Media Generation ---
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=

# --- Other ---
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8787
