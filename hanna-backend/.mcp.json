{
  "mcpServers": {
    "unified-browser": {
      "command": "python",
      "args": ["tools/unified-browser-mcp/server.py"],
      "description": "Browser control for all agent personalities (Hanna, Director, Sensei, Alpha, Beta, Gamma)",
      "timeout": 300,
      "tools": [
        "create_session",
        "navigate",
        "get_text",
        "get_html",
        "screenshot",
        "click",
        "fill",
        "evaluate",
        "close_session",
        "list_sessions"
      ]
    },
    "blender": {
      "command": "python",
      "args": ["tools/blender-mcp/server.py"],
      "env": {
        "BLENDER_PATH": "${BLENDER_PATH:-blender}"
      },
      "tools": [
        "create_anime_avatar",
        "render_scene",
        "apply_kupuri_shader",
        "export_web_avatar"
      ]
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server"],
      "env": {
        "SUPABASE_URL": "${SUPABASE_URL}",
        "SUPABASE_SERVICE_KEY": "${SUPABASE_SERVICE_KEY}"
      },
      "tools": [
        "query",
        "insert",
        "update",
        "storage_upload",
        "storage_list"
      ]
    }
  }
}
